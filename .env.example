# Ardur content pipeline — environment defaults
# Cost-guarded, pluggable AI provider. Default is the deterministic, zero-cost path.

# Provider: deterministic | ollama | openai | hermes
ARDUR_AI_PROVIDER=deterministic
# Hard kill switch: 0 forces deterministic regardless of provider
ARDUR_AI_ENABLED=1
# Per-run generation budget; deterministic fallback after this many model calls
ARDUR_AI_MAX_GENERATIONS=20
# Per-call timeout (ms) before falling back
ARDUR_AI_TIMEOUT_MS=20000

# Ollama (local-first; cloud only if OLLAMA_API_KEY is set)
# OLLAMA_HOST=http://127.0.0.1:11434
# OLLAMA_MODEL=minimax-m2.5:cloud
# OLLAMA_API_KEY=

# OpenAI (optional)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-5.5

# Hermes Agent CLI provider (optional, explicit-only)
# The aggregator still owns IDs/provenance/Zod/copyright/fallback; Hermes returns candidate JSON only.
# HERMES_FACT_EXTRACT_COMMAND=hermes
# HERMES_FACT_EXTRACT_ARGS=["chat","-Q","--toolsets","safe","--query","{prompt}"]
# HERMES_FACT_EXTRACT_MODEL=hermes-agent
