{
  "name": "@ardurai/news-aggregator",
  "version": "0.1.0",
  "private": false,
  "description": "Global multi-source news ingestion, dedup, clustering, and interaction-metric capture for the Ardur AI content pipeline",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "ardur-news-aggregator": "./dist/runners.js"
  },
  "files": [
    "dist",
    "src",
    "data"
  ],
  "scripts": {
    "prepare": "npm run build",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --test --experimental-strip-types src/smoke.test.ts",
    "test:package": "node scripts/verify-package-install.mjs",
    "run": "node --experimental-strip-types src/runners.ts",
    "aggregate": "node --experimental-strip-types src/cli.ts",
    "produce-golden": "node --experimental-strip-types src/cli.ts --out data/golden-sample.json --max-age-hours 168 --timeout 12000 --concurrency 12"
  },
  "keywords": [
    "ardur",
    "news",
    "aggregation",
    "clustering",
    "content-pipeline"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ArdurAI/ardur-news-aggregator.git"
  },
  "dependencies": {
    "@ardurai/contracts": "https://github.com/ArdurAI/ardur-contracts/archive/4a47ec8d7302ad3b62a481f83acd7df79709ef79.tar.gz",
    "fast-xml-parser": "^5.8.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0"
  }
}
